{
    "layer": "top", // Waybar at top layer
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 40, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    "spacing": 8, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": [
        // "hyprland/workspaces"
        //"hyprland/mode",
        //"hyprland/scratchpad",
        "custom/hostname",
        "custom/media",
        "custom/roon",
        "custom/workvpn"
    ],
    "modules-center": [
        "hyprland/workspaces"
    ],
    "modules-right": [
        "custom/audioname",
        "pulseaudio",
        "cpu",
        "memory",
        "clock",
        "tray"
    ],
    // Modules configuration
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": " {name}: {icon} ",
        "format-icons": {
            "1": "main",
            "2": "rdp",
            "3": "slack",
            "4": "music",
            "5": "discord",
            "6": "vpn"
        }
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "яБо",
            "deactivated": "яБ░"
        }
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        "timezone": "Canada/Eastern",
        "interval": 1,
        "format": "яР║ {:%Y-%m-%d %H:%M:%S}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
        "format": "cpu: {usage}%"
    },
    "memory": {
        "format": "ram: {}%"
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C",
        "format": "{temperatureC}┬░C {icon}",
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": [
            "юОН",
            "юПУ",
            "юПС",
            "юПП",
            "юПО",
            "юПН",
            "юПК",
            "юПИ",
            "юОЫ"
        ]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity} ґ░ВЙ",
        "format-plugged": "{capacity}% яЗж",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": [
            "яЙД",
            "яЙГ",
            "яЙВ",
            "яЙБ",
            "яЙА"
        ]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%) яЗл",
        "format-disconnected": "Disconnected тЪа",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "яАе {volume}%",
        "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
        "format-bluetooth-muted": "{icon}яКФ {format_source}",
        "format-source": "{volume}% яД░",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": [
                "яАж",
                "яАз",
                "яАи"
            ]
        },
        "on-click": "pavucontrol"
    },
    "custom/hostname": {
        "format": "яСР {}",
        "exec": "fish -c 'echo $(whoami)@$hostname'",
        "interval": 3600
    },
    "custom/media": {
        "format": "яЖ╝ {}",
        "interval": 10,
        "max-length": 100,
        "format-icons": {
            "spotify": "яЖ╝"
        },
        "exec": "[ $(playerctl status) == \"Playing\" ] && playerctl metadata --format \"{{ lc(artist) }} - {{ lc(title) }}\""
    },
    "custom/roon": {
        "format": "roon: {}",
        "interval": 20,
        "max-length": 50,
        "exec": "npm run --prefix \"~/repos/roon/\" start --silent | awk '{print tolower($0)}'"
    },
    "custom/workvpn": {
        "format": "{}",
        "exec": "fish ~/repos/scripts/workvpn_status.fish"
    },
    "custom/audioname": {
        "format": "{}",
        "exec": "fish ~/repos/scripts/audio_name.fish"
    }
}
